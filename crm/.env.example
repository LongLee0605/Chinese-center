# =============================================================================
# CRM – Backend API (chọn ĐÚNG môi trường, không trộn local với production)
# =============================================================================
#
# LOCAL: Copy nội dung dưới vào .env.development (hoặc .env khi chạy npm run dev)
#        CRM local → backend local → database local. Upload ảnh chỉ lưu trên máy.
#
# PRODUCTION: Dùng .env.production khi build (Cloudflare Pages dùng biến Build env).
#             CRM production → backend Render → database Render. Upload ảnh lưu trên Render.
#
# =============================================================================

# LOCAL – chạy backend trên máy (cd backend && npm run dev)
VITE_API_URL=http://localhost:4000/api/v1

# PRODUCTION – không set vào file khi dev; Cloudflare Pages set VITE_API_URL khi build
# VITE_API_URL=https://chinese-center.onrender.com/api/v1
