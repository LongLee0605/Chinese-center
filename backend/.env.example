# =============================================================================
# LOCAL DEVELOPMENT – Chỉ dùng khi chạy backend trên máy (npm run dev)
# Database: PHẢI dùng PostgreSQL local (Docker / máy). KHÔNG dùng URL DB của Render.
# =============================================================================

# Database – LOCAL (Docker: chinese_center, hoặc PostgreSQL cài trên máy)
DATABASE_URL="postgresql://chinese:chinese123@localhost:5432/chinese_center?schema=public"

# JWT (CRM + API)
JWT_SECRET="your-super-secret-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Server
PORT=4000
NODE_ENV=development

# CORS – chỉ cần localhost khi chạy local
CORS_ORIGINS="http://localhost:5173,http://localhost:5174"

# Mail (SMTP) – tùy chọn
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@chinese-center.local

LEAD_OWNER_EMAIL=your@email.com

# =============================================================================
# PRODUCTION (Render) – KHÔNG copy vào .env khi chạy local.
# Trên Render: set trực tiếp trong Dashboard (Environment).
# DATABASE_URL = Internal Database URL từ Postgres service (Render).
# CORS_ORIGINS = URL Cloudflare Pages / domain frontend, cách nhau dấu phẩy.
# =============================================================================
