# Database
DATABASE_URL="postgresql://user:password@localhost:5432/chinese_center?schema=public"

# JWT (CRM + API)
JWT_SECRET="your-super-secret-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Server
PORT=4000
NODE_ENV=development

# CORS (frontend + CRM origins)
CORS_ORIGINS="http://localhost:5173,http://localhost:5174"

# Mail (SMTP) - optional, for CRM gửi email
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@chinese-center.local

# Email nhận lead từ website (form Liên hệ + Đăng ký học thử)
LEAD_OWNER_EMAIL=letrandanglong.0605@gmail.com
